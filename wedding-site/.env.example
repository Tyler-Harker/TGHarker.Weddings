# Copy to .env.local for local development (`npm run dev`).
# These values match the Postgres container in docker-compose.yml.

# When running `npm run dev` on the host, connect to the compose Postgres on localhost.
# (The app container itself uses postgres://wedding:wedding@db:5432/wedding — see docker-compose.yml.)
DATABASE_URL=postgres://wedding:wedding@localhost:5432/wedding

# Secret used to sign RSVP + admin session JWTs. Generate a strong value for production:
#   openssl rand -base64 32
JWT_SECRET=dev-secret-change-me

# Admin login for /admin (change for production).
ADMIN_EMAIL=test@test.com
ADMIN_PASSWORD=password
